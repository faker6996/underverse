{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@underverse-ui/underverse": ["packages/underverse/src/index.ts"],
      "@tiptap/*": ["./node_modules/@tiptap/*"]
    }
  },
  "exclude": [
    "node_modules",
    "app/api/**",
    "components/admin/**",
    "components/login/**",
    "components/profile/**",
    "components/register/**",
    "components/settings/**",
    "components/users/**",
    "components/video/**",
    "lib/cache/**",
    "lib/models/**",
    "lib/modules/**",
    "lib/middlewares/**",
    "lib/utils/auth-helper.ts",
    "lib/utils/realtime.ts",
    "packages/**"
  ]
}
